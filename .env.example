# Copy this file to ".env" and fill in the values.
# The real .env must NEVER be committed (it is in .gitignore).

# Discord bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=

# Application (client) ID — needed to register slash commands
CLIENT_ID=

# ID of the Pokemon GO - Pau community server (guild)
GUILD_ID=

# Optional: ID of the voice channel that displays the live member count
# as "Membres : {nb}". The bot needs "Manage Channels" on it.
MEMBER_COUNT_CHANNEL_ID=

# "Pending" role assigned to newcomers until a moderator validates them.
VERIFICATION_ROLE_ID=

# Optional: restrict the verification flow to a single channel (else any channel).
VERIFICATION_CHANNEL_ID=

# "Join to create" hub voice channel: joining it spawns a personal channel.
TEMP_VOICE_HUB_ID=

# Category where /rdv creates its temporary meetup channels.
RDV_CATEGORY_ID=
