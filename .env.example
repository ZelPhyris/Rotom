# Copy this file to ".env" and fill in the values.
# The real .env must NEVER be committed (it is in .gitignore).

# Discord bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=

# Application (client) ID — needed to register slash commands
CLIENT_ID=

# ID of the Pokemon GO - Pau community server (guild)
GUILD_ID=

# Optional: ID of the voice channel that displays the live member count
# as "Membres : {nb}". The bot needs "Manage Channels" on it.
MEMBER_COUNT_CHANNEL_ID=

# "Pending" role assigned to newcomers until a moderator validates them.
VERIFICATION_ROLE_ID=

# Optional: restrict the verification flow to a single channel (else any channel).
VERIFICATION_CHANNEL_ID=

# "Join to create" hub voice channel: joining it spawns a personal channel.
TEMP_VOICE_HUB_ID=

# Category where /rdv creates its temporary meetup channels.
RDV_CATEGORY_ID=

# Channel where /rdv announces newly created meetups.
RDV_ANNOUNCE_CHANNEL_ID=

# Channel where a welcome message is posted once a newcomer is validated.
WELCOME_CHANNEL_ID=

# --- Database (Docker) ---
# Password for the PostgreSQL container. Used by docker-compose for both the
# db service and the bot's DATABASE_URL. Choose a strong value.
POSTGRES_PASSWORD=

# PostgreSQL connection string. In docker-compose it is injected automatically
# (postgres://rotom:<POSTGRES_PASSWORD>@db:5432/rotom). Only set it manually if
# you run the bot OUTSIDE Docker against your own database.
DATABASE_URL=

# --- Vision (optional) ---
# Google Gemini API key (free tier) — lets the bot read PoGo profile screenshots
# and auto-detect the trainer name on validation. Free key: https://aistudio.google.com/apikey
# Leave empty to disable.
GEMINI_API_KEY=

# Vision model (default: gemini-2.5-flash, free tier).
VISION_MODEL=

# --- Leveling (optional) ---
# Channel for level-up messages (else the channel where it happened).
LEVELUP_CHANNEL_ID=

# Reward roles by level: "10:roleId,20:roleId,30:roleId" (a role each 10 levels).
LEVEL_ROLES=

# --- Forum ❤️ ---
# Forum channel where the bot reacts ❤️ to posted images.
FORUM_HEART_CHANNEL_ID=
